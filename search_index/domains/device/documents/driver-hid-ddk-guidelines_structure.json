  "development_guides": [
    {
      "name": "HID基础驱动能力开发",
      "steps": [
        "添加动态链接库 libhid.z.so",
        "包含头文件 hid/hid_ddk_api.h 和 hid/hid_ddk_types.h",
        "使用 OH_Hid_CreateDevice 创建HID设备",
        "使用 OH_Hid_EmitEvent 向指定deviceId的HID设备发送事件",
        "使用 OH_Hid_DestroyDevice 销毁HID设备"
      ]
    },
    {
      "name": "HID报文通信驱动能力开发",
      "steps": [
        "添加动态链接库 libhid.z.so",
        "包含头文件 hid/hid_ddk_api.h 和 hid/hid_ddk_types.h",
        "使用 OH_Hid_Init 初始化HidDdk",
        "使用 OH_Hid_Open 打开HID设备",
        "使用 OH_Hid_Write 或 OH_Hid_SendReport 向HID设备写入/发送报告",
        "使用 OH_Hid_Read、OH_Hid_ReadTimeout 或 OH_Hid_GetReport 从HID设备读取报告",
        "使用 OH_Hid_GetRawInfo、OH_Hid_GetRawName、OH_Hid_GetPhysicalAddress、OH_Hid_GetRawUniqueId 获取设备信息",
        "使用 OH_Hid_GetReportDescriptor 获取报告描述符",
        "使用 OH_Hid_Close 关闭设备",
        "使用 OH_Hid_Release 释放HidDdk"
      ]
    }
