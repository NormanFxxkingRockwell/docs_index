  "apis": [
    {
      "name": "requestPictureInPicture",
      "type": "method",
      "interface": "HTMLVideoElement",
      "description": "请求启动画中画，如果系统支持画中画能力，则会以画中画模式显示视频"
    },
    {
      "name": "exitPictureInPicture",
      "type": "method",
      "interface": "Document",
      "description": "请求退出画中画模式，视频将重新在原始标签页中显示"
    },
    {
      "name": "enterpictureinpicture",
      "type": "event",
      "interface": "HTMLVideoElement",
      "description": "在HTMLVideoElement成功进入画中画模式时触发"
    },
    {
      "name": "leavepictureinpicture",
      "type": "event",
      "interface": "HTMLVideoElement",
      "description": "在HTMLVideoElement成功退出画中画模式时触发"
    }
  ],
