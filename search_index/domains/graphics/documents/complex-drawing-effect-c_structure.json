              ]
            }
          ],
          "images": [
            "figures/zh-cn_image_0000002158584354.png"
          ],
          "keywords": [
            "扇形渐变",
            "OH_Drawing_ShaderEffectCreateSweepGradient"
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "滤波器效果",
      "line": 262,
      "content": "滤波器效果可基于画刷或画笔实现。可使用OH_Drawing_PenSetFilter()接口设置画笔的滤波器效果，或者使用OH_Drawing_BrushSetFilter()接口设置画刷的滤波器效果。当前支持不同的滤波器效果，比如图像滤波器、颜色滤波器、蒙版滤波器。",
      "keywords": [
        "滤波器效果",
        "OH_Drawing_PenSetFilter",
        "OH_Drawing_BrushSetFilter",
        "图像滤波器",
        "颜色滤波器",
        "蒙版滤波器"
      ],
      "subsections": [
        {
          "level": 3,
          "title": "颜色滤波器效果",
          "line": 269,
          "content": "颜色滤波器可基于画笔或画刷实现。目前可实现多种颜色滤波器，包括：具有混合模式的颜色滤波器、具有5x4颜色矩阵的颜色滤波器、将SRGB的伽玛曲线应用到RGB颜色通道的颜色滤波器、将RGB颜色通道应用于SRGB的伽玛曲线的颜色滤波器、将其输入的亮度值乘以透明度通道的颜色滤波器、由两个颜色滤波器组合而成的颜色滤波器。",
          "code_blocks": [
            {
              "language": "C++",
              "start_line": 313,
              "end_line": 349,
              "functions": [
                "OH_Drawing_BrushCreate",
                "OH_Drawing_BrushSetAntiAlias",
                "OH_Drawing_BrushSetColor",
                "OH_Drawing_ColorFilterCreateMatrix",
                "OH_Drawing_FilterCreate",
                "OH_Drawing_FilterSetColorFilter",
                "OH_Drawing_BrushSetFilter",
                "OH_Drawing_CanvasAttachBrush",
                "OH_Drawing_RectCreate",
                "OH_Drawing_CanvasDrawRect",
                "OH_Drawing_CanvasDetachBrush",
                "OH_Drawing_BrushDestroy",
                "OH_Drawing_ColorFilterDestroy",
                "OH_Drawing_RectDestroy",
                "OH_Drawing_FilterDestroy"
              ]
            }
          ],
