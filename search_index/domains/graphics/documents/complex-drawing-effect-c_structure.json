  "summary": "本文档介绍了在C/C++中使用ArkGraphics 2D实现复杂绘制效果的方法，包括混合模式、路径效果、着色器效果（线性渐变、径向渐变、扇形渐变）和滤波器效果（颜色滤波器、图像滤波器、蒙版滤波器）的使用方法和代码示例。",
  "sections": [
    {
      "level": 2,
      "title": "混合模式",
      "line": 22,
      "content": "混合模式可以用于画笔或画刷，它定义了如何将源像素（要绘制的内容）与目标像素（已存在于画布上的内容）进行组合。可以使用OH_Drawing_BrushSetBlendMode()接口将混合模式应用于画刷中，使用OH_Drawing_PenSetBlendMode()接口将混合模式应用于画笔中。这两个接口都需要接受一个参数OH_Drawing_BlendMode，即混合模式的类型。",
      "code_blocks": [
        {
          "language": "C++",
          "start_line": 32,
          "end_line": 59,
          "functions": [
            "OH_Drawing_BrushCreate",
            "OH_Drawing_BrushSetColor",
            "OH_Drawing_CanvasAttachBrush",
            "OH_Drawing_RectCreate",
            "OH_Drawing_CanvasDrawRect",
            "OH_Drawing_BrushSetBlendMode",
            "OH_Drawing_PointCreate",
            "OH_Drawing_CanvasDrawCircle",
            "OH_Drawing_CanvasDetachBrush",
            "OH_Drawing_RectDestroy",
            "OH_Drawing_BrushDestroy",
            "OH_Drawing_PointDestroy"
          ]
        }
      ],
      "images": [
        "figures/zh-cn_image_0000002158744138.png"
      ],
      "keywords": [
        "混合模式",
        "OH_Drawing_BrushSetBlendMode",
        "OH_Drawing_PenSetBlendMode",
        "OH_Drawing_BlendMode",
        "BLEND_MODE_PLUS"
      ]
    },
    {
      "level": 2,
      "title": "路径效果",
      "line": 64,
      "content": "路径效果如虚线效果，只用于画笔。可使用OH_Drawing_CreateDashPathEffect()接口设置路径效果。接口接受3个参数，分别为：浮点数数组intervals（表示虚线或者点线的间隔）、整数count（表示intervals数组中的元素数量）、浮点数phase（表示在intervals数组中的偏移量）。",
      "code_blocks": [
        {
          "language": "C++",
          "start_line": 80,
          "end_line": 104,
          "functions": [
            "OH_Drawing_PenCreate",
            "OH_Drawing_PenSetColor",
            "OH_Drawing_PenSetWidth",
            "OH_Drawing_CreateDashPathEffect",
            "OH_Drawing_PenSetPathEffect",
            "OH_Drawing_CanvasAttachPen",
            "OH_Drawing_RectCreate",
            "OH_Drawing_CanvasDrawRect",
            "OH_Drawing_CanvasDetachPen",
            "OH_Drawing_PenDestroy",
            "OH_Drawing_RectDestroy",
            "OH_Drawing_PathEffectDestroy"
          ]
        }
      ],
      "images": [
        "figures/zh-cn_image_0000002158584342.png",
        "figures/zh-cn_image_0000002194110865.png"
      ],
      "keywords": [
        "路径效果",
        "虚线",
        "OH_Drawing_CreateDashPathEffect",
        "OH_Drawing_PenSetPathEffect"
      ]
    },
    {
      "level": 2,
      "title": "着色器效果",
      "line": 111,
      "content": "着色器效果基于画刷或画笔实现，可使用OH_Drawing_BrushSetShaderEffect()接口设置画刷的着色器效果，或者使用OH_Drawing_PenSetShaderEffect()接口设置画笔的着色器效果。当前支持不同的着色器效果，如线性渐变着色器效果、径向渐变着色器效果、扇形渐变着色器效果。",
      "keywords": [
        "着色器效果",
        "OH_Drawing_BrushSetShaderEffect",
        "OH_Drawing_PenSetShaderEffect",
        "线性渐变",
        "径向渐变",
        "扇形渐变"
      ],
      "subsections": [
        {
          "level": 3,
          "title": "线性渐变着色器效果",
          "line": 118,
          "content": "可使用OH_Drawing_ShaderEffectCreateLinearGradient()接口创建想要设置的线性渐变着色器效果。接口接受6个参数，分别为开始点、结束点、颜色数组、相对位置数组、颜色数组的大小以及平铺模式。",
          "code_blocks": [
            {
              "language": "C++",
              "start_line": 138,
              "end_line": 167,
              "functions": [
                "OH_Drawing_PointCreate",
                "OH_Drawing_ShaderEffectCreateLinearGradient",
                "OH_Drawing_BrushCreate",
                "OH_Drawing_BrushSetShaderEffect",
                "OH_Drawing_CanvasAttachBrush",
                "OH_Drawing_RectCreate",
                "OH_Drawing_CanvasDrawRect",
                "OH_Drawing_CanvasDetachBrush",
                "OH_Drawing_BrushDestroy",
                "OH_Drawing_RectDestroy",
                "OH_Drawing_ShaderEffectDestroy",
                "OH_Drawing_PointDestroy"
              ]
            }
          ],
          "images": [
            "figures/zh-cn_image_0000002194110873.png"
          ],
          "keywords": [
            "线性渐变",
            "OH_Drawing_ShaderEffectCreateLinearGradient",
            "CLAMP",
            "REPEAT",
            "MIRROR",
            "DECAL"
          ]
        },
        {
          "level": 3,
          "title": "径向渐变着色器效果",
          "line": 174,
          "content": "可使用OH_Drawing_ShaderEffectCreateRadialGradient()接口创建想要设置的径向渐变着色器效果。接口接受6个参数，分别为圆心坐标（centerPt）、半径（radius）、颜色数组（colors）、相对位置数组（pos）、颜色和位置的数量（size）以及平铺模式（OH_Drawing_TileMode）。径向渐变是由圆心开始开始向外径向渐变的。",
          "code_blocks": [
            {
              "language": "C++",
              "start_line": 184,
              "end_line": 212,
              "functions": [
                "OH_Drawing_PointCreate",
                "OH_Drawing_ShaderEffectCreateRadialGradient",
                "OH_Drawing_BrushCreate",
                "OH_Drawing_BrushSetShaderEffect",
                "OH_Drawing_CanvasAttachBrush",
                "OH_Drawing_RectCreate",
                "OH_Drawing_CanvasDrawRect",
                "OH_Drawing_CanvasDetachBrush",
                "OH_Drawing_BrushDestroy",
                "OH_Drawing_RectDestroy",
                "OH_Drawing_ShaderEffectDestroy",
                "OH_Drawing_PointDestroy"
              ]
            }
          ],
          "images": [
            "figures/zh-cn_image_0000002158744130.png"
          ],
          "keywords": [
            "径向渐变",
            "OH_Drawing_ShaderEffectCreateRadialGradient"
          ]
        },
        {
          "level": 3,
          "title": "扇形渐变着色器效果",
          "line": 219,
          "content": "可使用OH_Drawing_ShaderEffectCreateSweepGradient()接口创建想要设置的扇形渐变着色器效果。接口接受5个参数，分别是中心点、颜色数组、相对位置数组、颜色和相对位置的数量以及平铺模式。扇形渐变是在围绕中心点旋转的过程中渐变。",
          "code_blocks": [
            {
              "language": "C++",
              "start_line": 229,
              "end_line": 255,
              "functions": [
                "OH_Drawing_PointCreate",
                "OH_Drawing_ShaderEffectCreateSweepGradient",
                "OH_Drawing_BrushCreate",
                "OH_Drawing_BrushSetShaderEffect",
                "OH_Drawing_CanvasAttachBrush",
                "OH_Drawing_RectCreate",
                "OH_Drawing_CanvasDrawRect",
                "OH_Drawing_CanvasDetachBrush",
                "OH_Drawing_BrushDestroy",
